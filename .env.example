# Global Skills Sync Configuration — EXAMPLE
# Copy this file to .env and fill in your paths.
#
# SYNC_TARGETS: comma or colon separated absolute paths to repos
# that should have global skills symlinked into them.
# Tilde (~) expansion is supported.
#
# Example:
# SYNC_TARGETS=/Users/yourname/Code/my-api,/Users/yourname/Code/my-frontend

SYNC_TARGETS=
